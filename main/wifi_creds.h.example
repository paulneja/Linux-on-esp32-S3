/*
 * WiFi STA uplink credentials — the home network the ESP32 joins to give the
 * emulated Linux guest internet access (NAT'd out over this connection).
 *
 * SETUP: copy this file to "wifi_creds.h" and edit the two values below with
 * your own home WiFi. The real wifi_creds.h is gitignored so your password is
 * never committed.
 *
 *     cp main/wifi_creds.h.example main/wifi_creds.h
 *     # then edit main/wifi_creds.h
 */
#ifndef WIFI_CREDS_H
#define WIFI_CREDS_H

#define STA_SSID "YOUR_WIFI_SSID"
#define STA_PASS "YOUR_WIFI_PASSWORD"

#endif /* WIFI_CREDS_H */
