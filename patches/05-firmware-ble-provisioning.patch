diff --git a/esp_hosted_ng/esp/esp_driver/network_adapter/main/ble_prov.c b/esp_hosted_ng/esp/esp_driver/network_adapter/main/ble_prov.c
new file mode 100644
index 0000000..84497e5
--- /dev/null
+++ b/esp_hosted_ng/esp/esp_driver/network_adapter/main/ble_prov.c
@@ -0,0 +1,292 @@
+// SPDX-License-Identifier: Apache-2.0
+/*
+ * BLE provisioning link for Linux-on-ESP32-S3.
+ *
+ * Runs a NimBLE peripheral advertising as "Esp32-Linux" exposing the Nordic
+ * UART Service (NUS), the de-facto "serial over BLE" profile that phone apps
+ * (Serial Bluetooth Terminal, nRF Connect, ...) speak. The ESP32-S3 has no
+ * Bluetooth Classic, so SPP is not an option -- NUS over BLE is.
+ *
+ * Purpose: let the board be joined to a WiFi network from a phone, with no PC
+ * and no serial cable. This file is only the transport (a byte pipe); the
+ * provisioning dialog itself (scan, pick a network, ask for the password)
+ * lives on the Linux side, which is what owns the WiFi connection.
+ *
+ * Do NOT log from this file. Once Linux owns the USB-Serial-JTAG console,
+ * a printf from core 0 blocks forever, which hangs the NimBLE host task and
+ * kills GAP event processing -- the connection then dies during service
+ * discovery. ESP_LOG* are compiled out here anyway (LOG_MAXIMUM_LEVEL=1).
+ *
+ * Note this deliberately does NOT use esp-hosted's slave_bt.c HCI passthrough:
+ * that hands the controller to the Linux host for BlueZ, which cannot run on
+ * this NOMMU/8MB target. Here the controller stays with NimBLE on core 0.
+ */
+
+/* sdkconfig.h first: ESP-IDF does not force-include it, and the guard below
+ * needs CONFIG_BT_ENABLED to be defined or this whole file compiles to
+ * nothing (which is exactly how ble_prov_init ended up undefined once). */
+#include "sdkconfig.h"
+
+#ifdef CONFIG_BT_ENABLED
+
+#include <string.h>
+#include "esp_log.h"
+#include <stdio.h>
+#include "nvs_flash.h"
+
+#include "nimble/nimble_port.h"
+#include "nimble/nimble_port_freertos.h"
+#include "host/ble_hs.h"
+#include "host/util/util.h"
+#include "services/gap/ble_svc_gap.h"
+#include "services/gatt/ble_svc_gatt.h"
+
+#include "interface.h"
+#include "adapter.h"
+#include "ble_prov.h"
+
+/* Owned by app_main: the queues that carry packets up to Linux. */
+extern QueueHandle_t to_host_queue[MAX_PRIORITY_QUEUES];
+
+static const char *TAG = "BLE_PROV";
+
+#define BLE_PROV_DEVICE_NAME "Esp32-Linux"
+
+/* Nordic UART Service UUIDs (128-bit, NimBLE wants them little-endian). */
+/* 6E400001-B5A3-F393-E0A9-E50E24DCCA9E */
+static const ble_uuid128_t nus_svc_uuid =
+	BLE_UUID128_INIT(0x9e, 0xca, 0xdc, 0x24, 0x0e, 0xe5, 0xa9, 0xe0,
+			 0x93, 0xf3, 0xa3, 0xb5, 0x01, 0x00, 0x40, 0x6e);
+/* 6E400002-... : RX, phone -> board (write) */
+static const ble_uuid128_t nus_rx_uuid =
+	BLE_UUID128_INIT(0x9e, 0xca, 0xdc, 0x24, 0x0e, 0xe5, 0xa9, 0xe0,
+			 0x93, 0xf3, 0xa3, 0xb5, 0x02, 0x00, 0x40, 0x6e);
+/* 6E400003-... : TX, board -> phone (notify) */
+static const ble_uuid128_t nus_tx_uuid =
+	BLE_UUID128_INIT(0x9e, 0xca, 0xdc, 0x24, 0x0e, 0xe5, 0xa9, 0xe0,
+			 0x93, 0xf3, 0xa3, 0xb5, 0x03, 0x00, 0x40, 0x6e);
+
+static uint8_t own_addr_type;
+static uint16_t conn_handle = BLE_HS_CONN_HANDLE_NONE;
+static uint16_t tx_val_handle;
+
+static void start_advertising(void);
+
+/* --- sending: board -> phone -------------------------------------------- */
+int ble_prov_send(const char *data, int len)
+{
+	struct os_mbuf *om;
+
+	if (conn_handle == BLE_HS_CONN_HANDLE_NONE || !tx_val_handle)
+		return -1;
+
+	om = ble_hs_mbuf_from_flat(data, len);
+	if (!om)
+		return -1;
+
+	return ble_gatts_notify_custom(conn_handle, tx_val_handle, om);
+}
+
+/* --- receiving: phone -> board ------------------------------------------ */
+static int nus_access_cb(uint16_t c_handle, uint16_t attr_handle,
+			 struct ble_gatt_access_ctxt *ctxt, void *arg)
+{
+	uint16_t len;
+	char buf[256];
+
+	if (ctxt->op != BLE_GATT_ACCESS_OP_WRITE_CHR)
+		return BLE_ATT_ERR_UNLIKELY;
+
+	len = OS_MBUF_PKTLEN(ctxt->om);
+	if (len >= sizeof(buf))
+		len = sizeof(buf) - 1;
+
+	if (ble_hs_mbuf_to_flat(ctxt->om, buf, len, &len) != 0)
+		return BLE_ATT_ERR_UNLIKELY;
+	buf[len] = '\0';
+
+
+	/* Hand the bytes to Linux, which runs the actual provisioning dialog
+	 * (it owns the WiFi connection, so the scan and the join must happen
+	 * there). This side is only a pipe. */
+	ble_prov_to_linux(buf, len);
+
+	return 0;
+}
+
+/* --- the pipe: BLE <-> Linux -------------------------------------------- */
+int ble_prov_to_linux(const char *data, int len)
+{
+	interface_buffer_handle_t buf_handle;
+	uint8_t *buf;
+
+	/* app_main creates these later than this file is initialised; a phone
+	 * that writes before then would otherwise assert inside xQueueSend. */
+	if (!to_host_queue[PRIO_Q_MID])
+		return -1;
+
+	buf = malloc(len);
+	if (!buf) {
+		return -1;
+	}
+	memcpy(buf, data, len);
+
+	memset(&buf_handle, 0, sizeof(buf_handle));
+	buf_handle.if_type = ESP_BLE_PROV_IF;
+	buf_handle.if_num = 0;
+	buf_handle.payload_len = len;
+	buf_handle.payload = buf;
+	buf_handle.wlan_buf_handle = buf;
+	buf_handle.free_buf_handle = free;
+
+	if (xQueueSend(to_host_queue[PRIO_Q_MID], &buf_handle,
+		       portMAX_DELAY) != pdTRUE) {
+		free(buf);
+		return -1;
+	}
+
+	return 0;
+}
+
+/* Called from app_main's RX dispatch when Linux sends us bytes destined for
+ * the phone (the menu, prompts, results). */
+void ble_prov_from_linux(const uint8_t *payload, uint16_t len)
+{
+	/* Nothing connected: the bytes are simply dropped. Cannot log here,
+	 * see the note at the top of this file. */
+	(void)ble_prov_send((const char *)payload, len);
+}
+
+static const struct ble_gatt_svc_def gatt_svcs[] = {
+	{
+		.type = BLE_GATT_SVC_TYPE_PRIMARY,
+		.uuid = &nus_svc_uuid.u,
+		.characteristics = (struct ble_gatt_chr_def[]) {
+			{
+				.uuid = &nus_rx_uuid.u,
+				.access_cb = nus_access_cb,
+				.flags = BLE_GATT_CHR_F_WRITE |
+					 BLE_GATT_CHR_F_WRITE_NO_RSP,
+			}, {
+				.uuid = &nus_tx_uuid.u,
+				.access_cb = nus_access_cb,
+				.val_handle = &tx_val_handle,
+				.flags = BLE_GATT_CHR_F_NOTIFY,
+			}, {
+				0,
+			}
+		},
+	},
+	{
+		0,
+	},
+};
+
+/* --- connection lifecycle ----------------------------------------------- */
+static int gap_event_cb(struct ble_gap_event *event, void *arg)
+{
+
+	switch (event->type) {
+	case BLE_GAP_EVENT_CONNECT:
+		if (event->connect.status == 0) {
+			conn_handle = event->connect.conn_handle;
+		} else {
+			start_advertising();
+		}
+		break;
+
+	case BLE_GAP_EVENT_DISCONNECT:
+		conn_handle = BLE_HS_CONN_HANDLE_NONE;
+		start_advertising();
+		break;
+
+	case BLE_GAP_EVENT_ADV_COMPLETE:
+		start_advertising();
+		break;
+
+	default:
+		break;
+	}
+
+	return 0;
+}
+
+static void start_advertising(void)
+{
+	struct ble_gap_adv_params adv_params;
+	struct ble_hs_adv_fields fields;
+	const char *name = ble_svc_gap_device_name();
+	int rc;
+
+	memset(&fields, 0, sizeof(fields));
+	fields.flags = BLE_HS_ADV_F_DISC_GEN | BLE_HS_ADV_F_BREDR_UNSUP;
+	fields.name = (uint8_t *)name;
+	fields.name_len = strlen(name);
+	fields.name_is_complete = 1;
+
+	rc = ble_gap_adv_set_fields(&fields);
+	if (rc) {
+		return;
+	}
+
+	memset(&adv_params, 0, sizeof(adv_params));
+	adv_params.conn_mode = BLE_GAP_CONN_MODE_UND;
+	adv_params.disc_mode = BLE_GAP_DISC_MODE_GEN;
+
+	rc = ble_gap_adv_start(own_addr_type, NULL, BLE_HS_FOREVER,
+			       &adv_params, gap_event_cb, NULL);
+	(void)rc;
+}
+
+static void on_sync(void)
+{
+	if (ble_hs_util_ensure_addr(0) != 0 ||
+	    ble_hs_id_infer_auto(0, &own_addr_type) != 0) {
+		return;
+	}
+	start_advertising();
+}
+
+static void on_reset(int reason)
+{
+}
+
+static void host_task(void *param)
+{
+	nimble_port_run();
+	nimble_port_freertos_deinit();
+}
+
+esp_err_t ble_prov_init(void)
+{
+	int rc;
+
+	rc = nimble_port_init();
+	if (rc != ESP_OK) {
+		return rc;
+	}
+
+	ble_hs_cfg.sync_cb = on_sync;
+	ble_hs_cfg.reset_cb = on_reset;
+
+	ble_svc_gap_init();
+	ble_svc_gatt_init();
+
+	rc = ble_gatts_count_cfg(gatt_svcs);
+	if (rc) {
+		return ESP_FAIL;
+	}
+	rc = ble_gatts_add_svcs(gatt_svcs);
+	if (rc) {
+		return ESP_FAIL;
+	}
+
+	rc = ble_svc_gap_device_name_set(BLE_PROV_DEVICE_NAME);
+	(void)rc;
+
+	nimble_port_freertos_init(host_task);
+
+	return ESP_OK;
+}
+
+#endif /* CONFIG_BT_ENABLED */
