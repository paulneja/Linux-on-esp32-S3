 	ESP_MAX_IF,
 };
 
diff --git a/esp_hosted_ng/esp/esp_driver/network_adapter/main/include/ble_prov.h b/esp_hosted_ng/esp/esp_driver/network_adapter/main/include/ble_prov.h
new file mode 100644
index 0000000..db958af
--- /dev/null
+++ b/esp_hosted_ng/esp/esp_driver/network_adapter/main/include/ble_prov.h
@@ -0,0 +1,26 @@
+// SPDX-License-Identifier: Apache-2.0
+/*
+ * BLE provisioning link (Nordic UART Service over BLE) — see ble_prov.c.
+ */
+
+#ifndef __BLE_PROV_H__
+#define __BLE_PROV_H__
+
+#include <stdint.h>
+#include "esp_err.h"
+
+/* Start the NimBLE peripheral advertising as "Esp32-Linux". */
+esp_err_t ble_prov_init(void);
+
+/* Send bytes to the connected phone (notify on the NUS TX characteristic).
+ * Returns 0 on success, negative if nothing is connected. */
+int ble_prov_send(const char *data, int len);
+
+/* Pipe a chunk received from the phone up to Linux (ESP_BLE_PROV_IF). */
+int ble_prov_to_linux(const char *data, int len);
+
+/* Deliver a chunk coming down from Linux to the phone. Called from the
+ * app_main RX dispatch. */
+void ble_prov_from_linux(const uint8_t *payload, uint16_t len);
+
+#endif /* __BLE_PROV_H__ */
