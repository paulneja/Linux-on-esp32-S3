+/* SoftAP with a fixed SSID/password, started automatically once the AP
+ * interface initializes -- there is no userspace daemon to trigger it
+ * dynamically (hostapd needs real fork(), unavailable on this NOMMU libc). */
+static esp_err_t start_softap_fixed(void)
+{
+	static const char ssid[] = "esp32-linux";
+	static const char password[] = "linux1234";
+	wifi_config_t wifi_config = {0};
+	esp_err_t ret;
+
+	memcpy(wifi_config.ap.ssid, ssid, sizeof(ssid) - 1);
+	wifi_config.ap.ssid_len = sizeof(ssid) - 1;
+	wifi_config.ap.channel = 6;
+	wifi_config.ap.authmode = WIFI_AUTH_WPA2_PSK;
+	wifi_config.ap.max_connection = 4;
+	wifi_config.ap.beacon_interval = 100;
+	strlcpy((char *) wifi_config.ap.password, password, sizeof(wifi_config.ap.password));
+
+	ret = esp_wifi_set_config(WIFI_IF_AP, &wifi_config);
+	if (ret) {
+		ESP_LOGE(TAG, "SoftAP: esp_wifi_set_config failed, ret=0x%x\n", ret);
+		return ret;
+	}
+
+	esp_update_ap_mac();
+
+	ret = esp_wifi_internal_reg_rxcb(ESP_IF_WIFI_AP, (wifi_rxcb_t) wlan_ap_rx_callback);
+	if (ret) {
+		ESP_LOGE(TAG, "SoftAP: failed to register AP rx callback, ret=0x%x\n", ret);
+		return ret;
+	}
+
+	softap_started = 1;
+	ESP_LOGI(TAG, "SoftAP '%s' starting on channel %u\n", ssid, wifi_config.ap.channel);
+	return ESP_OK;
+}
