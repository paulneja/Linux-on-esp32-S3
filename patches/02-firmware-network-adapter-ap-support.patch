+int process_ap_start(uint8_t if_type, uint8_t *payload, uint16_t payload_len)
+{
+	struct command_header *header;
+	interface_buffer_handle_t buf_handle = {0};
+	esp_err_t ret = ESP_OK;
+	uint8_t cmd_status = CMD_RESPONSE_SUCCESS;
+	struct cmd_ap_start *cmd;
+	wifi_config_t wifi_config = {0};
+	wifi_mode_t mode = WIFI_MODE_NULL;
+
+	cmd = (struct cmd_ap_start *) payload;
+
+	if (!cmd->ssid_len || cmd->ssid_len > 32) {
+		ESP_LOGE(TAG, "AP start: invalid ssid_len=%u\n", cmd->ssid_len);
+		cmd_status = CMD_RESPONSE_FAIL;
+		goto RESPOND;
+	}
+
+	memcpy(wifi_config.ap.ssid, cmd->ssid, cmd->ssid_len);
+	wifi_config.ap.ssid_len = cmd->ssid_len;
+	wifi_config.ap.channel = cmd->channel ? cmd->channel : 1;
+	wifi_config.ap.authmode = cmd->authmode;
+	wifi_config.ap.ssid_hidden = cmd->ssid_hidden;
+	wifi_config.ap.max_connection = cmd->max_connection ? cmd->max_connection : 4;
+	wifi_config.ap.beacon_interval = 100;
+	if (cmd->authmode != WIFI_AUTH_OPEN)
+		strlcpy((char *) wifi_config.ap.password, cmd->password,
+				sizeof(wifi_config.ap.password));
+
+	/* Wifi is already started by the STA interface's CMD_INIT_INTERFACE;
+	 * just widen the mode to APSTA so both coexist. */
+	ret = esp_wifi_get_mode(&mode);
+	if (ret == ESP_OK && mode != WIFI_MODE_APSTA) {
+		ret = esp_wifi_set_mode(WIFI_MODE_APSTA);
+		if (ret) {
+			ESP_LOGE(TAG, "AP start: failed to set APSTA mode, ret=0x%x\n", ret);
+			cmd_status = CMD_RESPONSE_FAIL;
+			goto RESPOND;
+		}
+	}
+
+	ret = esp_wifi_set_config(WIFI_IF_AP, &wifi_config);
+	if (ret) {
+		ESP_LOGE(TAG, "AP start: esp_wifi_set_config failed, ret=0x%x\n", ret);
+		cmd_status = CMD_RESPONSE_FAIL;
+		goto RESPOND;
+	}
+
+	esp_update_ap_mac();
+
+	ret = esp_wifi_internal_reg_rxcb(ESP_IF_WIFI_AP, (wifi_rxcb_t) wlan_ap_rx_callback);
+	if (ret) {
+		ESP_LOGE(TAG, "AP start: failed to register AP rx callback, ret=0x%x\n", ret);
+		cmd_status = CMD_RESPONSE_FAIL;
+		goto RESPOND;
+	}
+
+	softap_started = 1;
+	ESP_LOGI(TAG, "SoftAP configured: ssid_len=%u channel=%u authmode=%u\n",
+			cmd->ssid_len, wifi_config.ap.channel, cmd->authmode);
+
+RESPOND:
+	buf_handle.if_type = if_type;
+	buf_handle.if_num = 0;
+	buf_handle.payload_len = sizeof(struct command_header);
+	buf_handle.pkt_type = PACKET_TYPE_COMMAND_RESPONSE;
+
+	buf_handle.payload = heap_caps_malloc(buf_handle.payload_len, MALLOC_CAP_DMA);
+	assert(buf_handle.payload);
+	memset(buf_handle.payload, 0, buf_handle.payload_len);
+
+	header = (struct command_header *) buf_handle.payload;
+	header->cmd_code = CMD_AP_START;
+	header->len = 0;
+	header->cmd_status = cmd_status;
+
+	buf_handle.priv_buffer_handle = buf_handle.payload;
+	buf_handle.free_buf_handle = free;
+
+	ret = send_command_response(&buf_handle);
+	if (ret != pdTRUE) {
+		ESP_LOGE(TAG, "Slave -> Host: Failed to send command response\n");
+		goto DONE;
+	}
+
+	return ESP_OK;
+
+DONE:
+	if (buf_handle.payload) {
+		free(buf_handle.payload);
+		buf_handle.payload = NULL;
+	}
+
+	return ret;
+}
+
+int process_ap_stop(uint8_t if_type, uint8_t *payload, uint16_t payload_len)
+{
+	struct command_header *header;
+	interface_buffer_handle_t buf_handle = {0};
+	esp_err_t ret = ESP_OK;
+	uint8_t cmd_status = CMD_RESPONSE_SUCCESS;
+	wifi_mode_t mode = WIFI_MODE_NULL;
+
+	softap_started = 0;
+
+	ret = esp_wifi_get_mode(&mode);
+	if (ret == ESP_OK && (mode == WIFI_MODE_APSTA || mode == WIFI_MODE_AP)) {
+		wifi_mode_t new_mode = (mode == WIFI_MODE_APSTA) ? WIFI_MODE_STA : WIFI_MODE_NULL;
+		ret = esp_wifi_set_mode(new_mode);
+		if (ret) {
+			ESP_LOGE(TAG, "AP stop: failed to change wifi mode, ret=0x%x\n", ret);
+			cmd_status = CMD_RESPONSE_FAIL;
+		}
+	}
+
+	buf_handle.if_type = if_type;
+	buf_handle.if_num = 0;
+	buf_handle.payload_len = sizeof(struct command_header);
+	buf_handle.pkt_type = PACKET_TYPE_COMMAND_RESPONSE;
+
+	buf_handle.payload = heap_caps_malloc(buf_handle.payload_len, MALLOC_CAP_DMA);
+	assert(buf_handle.payload);
+	memset(buf_handle.payload, 0, buf_handle.payload_len);
+
+	header = (struct command_header *) buf_handle.payload;
+	header->cmd_code = CMD_AP_STOP;
+	header->len = 0;
+	header->cmd_status = cmd_status;
+
+	buf_handle.priv_buffer_handle = buf_handle.payload;
+	buf_handle.free_buf_handle = free;
+
+	ret = send_command_response(&buf_handle);
+	if (ret != pdTRUE) {
+		ESP_LOGE(TAG, "Slave -> Host: Failed to send command response\n");
+		goto DONE;
+	}
+
+	return ESP_OK;
+
+DONE:
+	if (buf_handle.payload) {
+		free(buf_handle.payload);
+		buf_handle.payload = NULL;
+	}
+
+	return ret;
+}
