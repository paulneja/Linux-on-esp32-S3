diff --git a/board/espressif/esp32s3/rootfs_overlay/etc/init.d/S05home b/board/espressif/esp32s3/rootfs_overlay/etc/init.d/S05home
new file mode 100755
index 0000000000..f948f23de5
--- /dev/null
+++ b/board/espressif/esp32s3/rootfs_overlay/etc/init.d/S05home
@@ -0,0 +1,34 @@
+#!/bin/sh
+#
+# Populate /home after the jffs2 partition is mounted by "mount -a" (inittab
+# runs that before rcS). A freshly erased jffs2 partition comes up empty, so
+# the home directories have to be created on first boot rather than shipped:
+# anything baked into the image would land on the read-only cramfs underneath
+# and be hidden by the mount.
+#
+
+HOMES="root"
+
+case "$1" in
+	start)
+		if ! mount | grep -q ' /home '; then
+			echo "S05home: /home is not mounted, skipping (see /home/README.txt)"
+			exit 0
+		fi
+		for h in $HOMES; do
+			if [ ! -d "/home/$h" ]; then
+				mkdir -p "/home/$h" || exit 1
+				chmod 700 "/home/$h"
+				echo "S05home: created /home/$h"
+			fi
+		done
+		;;
+	stop)
+		;;
+	restart|reload)
+		"$0" start
+		;;
+	*)
+		echo "Usage: $0 {start|stop|restart}"
+		exit 1
+esac
