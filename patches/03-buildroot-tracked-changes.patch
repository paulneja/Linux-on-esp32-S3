--- /dev/null
+++ b/configs/esp32s3_devkit_c1_16m_defconfig
@@ -0,0 +1,52 @@
+BR2_xtensa=y
+BR2_XTENSA_DYNCONFIG=y
+BR2_TOOLCHAIN_EXTERNAL=y
+BR2_TOOLCHAIN_EXTERNAL_PATH="/home/jcmvbkbc/ws/tensilica/crosstool/fdpic/builds/xtensa-esp32s3-linux-uclibcfdpic"
+BR2_TOOLCHAIN_EXTERNAL_CUSTOM_PREFIX="$(ARCH)-esp32s3-linux-uclibcfdpic"
+BR2_TOOLCHAIN_EXTERNAL_HEADERS_6_6=y
+BR2_TOOLCHAIN_EXTERNAL_WCHAR=y
+BR2_TOOLCHAIN_EXTERNAL_HAS_SSP=y
+BR2_OPTIMIZE_S=y
+# BR2_PIC_PIE is not set
+BR2_SSP_NONE=y
+BR2_RELRO_NONE=y
+BR2_ROOTFS_OVERLAY="board/espressif/esp32s3/rootfs_overlay"
+BR2_ROOTFS_POST_BUILD_SCRIPT="board/espressif/esp32s3/trim-libs.sh board/espressif/esp32s3/setup-home.sh"
+BR2_ROOTFS_POST_FAKEROOT_SCRIPT="board/espressif/esp32s3/mkfs-etc.sh"
+BR2_ROOTFS_POST_IMAGE_SCRIPT="board/espressif/esp32s3/post-build.sh"
+BR2_LINUX_KERNEL=y
+BR2_LINUX_KERNEL_CUSTOM_GIT=y
+BR2_LINUX_KERNEL_CUSTOM_REPO_URL="https://github.com/jcmvbkbc/linux-xtensa.git"
+BR2_LINUX_KERNEL_CUSTOM_REPO_VERSION="xtensa-6.11-esp32-tag"
+# SoftAP support for the esp32-ng driver (espap0 netdev + cfg80211
+# start_ap/stop_ap + CMD_AP_START/STOP over the shmem IPC protocol) is not
+# upstream. This directory is untracked by the kernel's own git repo, so a
+# clean re-extraction silently discards local edits made directly in the
+# build tree -- happened twice this session. BR2_LINUX_KERNEL_PATCH makes
+# buildroot re-apply the patch after every extraction instead.
+BR2_LINUX_KERNEL_PATCH="board/espressif/esp32s3/patches/linux"
+BR2_LINUX_KERNEL_USE_CUSTOM_CONFIG=y
+BR2_LINUX_KERNEL_CUSTOM_CONFIG_FILE="board/espressif/esp32s3/devkit_c1_16m_linux.config"
+BR2_LINUX_KERNEL_IMAGE_TARGET_CUSTOM=y
+BR2_LINUX_KERNEL_IMAGE_TARGET_NAME="xipImage"
+BR2_LINUX_KERNEL_NEEDS_HOST_OPENSSL=y
+BR2_PACKAGE_LINUX_TOOLS_GPIO=y
+BR2_PACKAGE_BUSYBOX_CONFIG="board/espressif/esp32s3/busybox.config"
+BR2_PACKAGE_DROPBEAR=y
+BR2_PACKAGE_IW=y
+BR2_PACKAGE_WIRELESS_REGDB=y
+BR2_PACKAGE_WPA_SUPPLICANT=y
+# hostapd needs real fork() (os_unix.c); this target's uclibc-fdpic is NOMMU
+# and does not declare it, so hostapd cannot be built here. The SoftAP is
+# started directly by the ESP32 firmware instead (fixed SSID, no hostapd).
+BR2_PACKAGE_IPTABLES=y
+# BR2_PACKAGE_URANDOM_SCRIPTS is not set
+# Deliberately obvious "changeme" default (not a plausible-looking fake
+# secure password) so it's unambiguous this MUST be changed via `passwd`
+# before any real deployment. SSH/telnet no longer allow blank passwords.
+BR2_TARGET_GENERIC_ROOT_PASSWD="changeme123"
+BR2_TARGET_ROOTFS_CRAMFS=y
+BR2_TARGET_ROOTFS_CRAMFS_XIP=y
+BR2_TARGET_ROOTFS_JFFS2=y
+BR2_TARGET_ROOTFS_JFFS2_FLASH_64=y
+# BR2_TARGET_ROOTFS_TAR is not set
