diff --git a/package/libcurl/libcurl.mk b/package/libcurl/libcurl.mk
index 3661cbf5bd..014f5143d8 100644
--- a/package/libcurl/libcurl.mk
+++ b/package/libcurl/libcurl.mk
@@ -84,7 +84,12 @@ LIBCURL_CONF_OPTS += --without-gnutls
 endif
 
 ifeq ($(BR2_PACKAGE_LIBCURL_MBEDTLS),y)
-LIBCURL_CONF_OPTS += --with-mbedtls=$(STAGING_DIR)/usr
+# The CA bundle lives on the read-only cramfs, NOT under /etc: on this board
+# /etc is a jffs2 partition mounted over the cramfs, so anything baked into
+# /etc/ssl is hidden at runtime. board/.../ca-bundle.sh builds this file from
+# the ca-certificates package.
+LIBCURL_CONF_OPTS += --with-mbedtls=$(STAGING_DIR)/usr \
+	--with-ca-bundle=/usr/share/ca-certificates/ca-bundle.crt
 LIBCURL_DEPENDENCIES += mbedtls
 else
 LIBCURL_CONF_OPTS += --without-mbedtls
