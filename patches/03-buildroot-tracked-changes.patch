diff --git a/board/espressif/esp32s3/rootfs_overlay/usr/sbin/wifi-setup b/board/espressif/esp32s3/rootfs_overlay/usr/sbin/wifi-setup
new file mode 100755
index 0000000000..b104fd1b7f
--- /dev/null
+++ b/board/espressif/esp32s3/rootfs_overlay/usr/sbin/wifi-setup
@@ -0,0 +1,36 @@
+#!/bin/sh
+#
+# Reconfigure the STA (home WiFi) uplink without recompiling/reflashing.
+# Always reachable via the fixed esp32-linux AP even if the STA side has
+# never been configured, since the two are independent (see PLAN.md/
+# ARCHITECTURE.md "the AP auto-starts from firmware").
+#
+# Usage: wifi-setup "SSID" "password"
+#
+
+if [ $# -ne 2 ]; then
+	echo "usage: $0 <ssid> <password>" >&2
+	exit 1
+fi
+
+SSID="$1"
+PASS="$2"
+CONF=/etc/wpa_supplicant.conf
+
+cat > "$CONF" << EOF
+network={
+	ssid="$SSID"
+	psk="$PASS"
+	key_mgmt=WPA-PSK
+	proto=WPA2
+	pairwise=CCMP
+	group=CCMP
+}
+EOF
+chmod 600 "$CONF"
+
+echo "Wrote $CONF for SSID '$SSID'. Restarting STA..."
+killall -q wpa_supplicant 2>/dev/null
+ifdown espsta0 2>/dev/null
+ifup espsta0
+echo "Done. Check with: ip addr show espsta0"
diff --git a/board/espressif/esp32s3/setup-home.sh b/board/espressif/esp32s3/setup-home.sh
new file mode 100755
index 0000000000..9a01b69374
--- /dev/null
+++ b/board/espressif/esp32s3/setup-home.sh
@@ -0,0 +1,20 @@
+#! /bin/sh
+#
+# Point root at /home/root instead of /root. Done here rather than in the
+# overlay because buildroot regenerates /etc/passwd after the overlay is
+# applied (it stamps the root password hash in), so an overlay copy would be
+# overwritten.
+#
+
+set -e
+
+chmod 0755 "$1/etc/init.d/S05home"
+chmod 0755 "$1/usr/bin/wifi"
+
+sed -i 's|^root:\([^:]*\):0:0:\([^:]*\):/root:|root:\1:0:0:\2:/home/root:|' \
+	"$1/etc/passwd"
+
+grep -q '^root:[^:]*:0:0:[^:]*:/home/root:' "$1/etc/passwd" || {
+	echo "setup-home.sh: failed to repoint root's home in /etc/passwd" >&2
+	exit 1
+}
diff --git a/configs/esp32s3_devkit_c1_16m_defconfig b/configs/esp32s3_devkit_c1_16m_defconfig
