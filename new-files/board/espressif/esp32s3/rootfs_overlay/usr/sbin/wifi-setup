#!/bin/sh
#
# Back-compat shim. The real WiFi manager is now `wifi` (interactive scan +
# picker, open/secured autodetect). This keeps the old scripted form working:
#
#   wifi-setup "SSID" "password"   ->   wifi connect "SSID" "password"
#
# For the friendly interactive flow just run:  wifi
#

if [ $# -ne 2 ]; then
	echo "usage: $0 <ssid> <password>" >&2
	echo "   or run 'wifi' for the interactive scanner." >&2
	exit 1
fi

exec wifi connect "$1" "$2"
