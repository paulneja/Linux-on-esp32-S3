#!/bin/sh
#
# Enable or disable the ESP32 SoftAP (espap0). It is OFF by default because it
# is still EXPERIMENTAL: the firmware's beacon currently advertises as WEP
# rather than WPA2 (see README), so clients may refuse it or fail to get an
# address. Turning it on brings up espap0, serves DHCP on 192.168.4.0/24 and
# NATs those clients out through the STA uplink (espsta0). This does not touch
# the STA connection, so the board keeps its own internet either way.
#
# The AP interface (espap0) always exists (module param esp32_wifi.ap_iface=Y);
# this just brings it up or down, which is what starts/stops the radio.
#

IFACE=espap0
GWIP=192.168.4.1
SUBNET=192.168.4.0/24
UPLINK=espsta0
DHCP_CONF=/etc/udhcpd.conf
DHCP_PID=/var/run/udhcpd.pid

case "$1" in
on|start)
	echo -n "Starting SoftAP ($IFACE): "
	ip link set $IFACE up 2>/dev/null
	ip addr add $GWIP/24 dev $IFACE 2>/dev/null
	echo 1 > /proc/sys/net/ipv4/ip_forward
	iptables -t nat -C POSTROUTING -s $SUBNET -o $UPLINK -j MASQUERADE 2>/dev/null \
		|| iptables -t nat -A POSTROUTING -s $SUBNET -o $UPLINK -j MASQUERADE
	start-stop-daemon -S -q -m -p $DHCP_PID -b -x /usr/sbin/udhcpd -- -S $DHCP_CONF
	echo "OK"
	echo "Note: the SoftAP is EXPERIMENTAL -- clients may see it as WEP. See README."
	;;
off|stop)
	echo -n "Stopping SoftAP ($IFACE): "
	start-stop-daemon -K -q -p $DHCP_PID 2>/dev/null
	rm -f $DHCP_PID
	iptables -t nat -D POSTROUTING -s $SUBNET -o $UPLINK -j MASQUERADE 2>/dev/null
	echo 0 > /proc/sys/net/ipv4/ip_forward
	ip addr flush dev $IFACE 2>/dev/null
	ip link set $IFACE down 2>/dev/null
	echo "OK"
	;;
status|"")
	if ip addr show $IFACE 2>/dev/null | grep -q "$GWIP"; then
		echo "SoftAP: ON  (SSID esp32-linux, gateway $GWIP)"
	else
		echo "SoftAP: off (experimental -- enable with: ap on)"
	fi
	;;
*)
	echo "usage: ap {on|off|status}" >&2
	exit 1
	;;
esac
